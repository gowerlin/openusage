{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenUsage",
  "version": "0.6.25",
  "identifier": "com.sunstory.openusage",
  "build": {
    "beforeDevCommand": "bun run bundle:plugins && bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run bundle:plugins && bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OpenUsage",
        "width": 400,
        "height": 500,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "dmg": {
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        },
        "windowSize": {
          "width": 660,
          "height": 400
        }
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/bundled_plugins/**/*",
      "icons/tray-icon.png"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZBRDMzOTBGN0Y0ODdCQTQKUldTa2UwaC9Eem5UK3R3K1FGT0xEby9wUDlaZ2dNREUvdXV5dXl3S3pKNytKUTFPQ2U0YmtFV04K",
      "endpoints": [
        "https://github.com/gowerlin/openusage/releases/latest/download/latest.json"
      ]
    }
  }
}
